{
  // Cloudflare Workers Static Assets — serves the landing page as a static site.
  // `wrangler deploy` reads this file; both Cloudflare's Git integration and the
  // GitHub Actions workflow use it, so they deploy identically every time.
  "name": "fudami-landing",
  "compatibility_date": "2026-06-11",
  "assets": {
    "directory": "."
  }
}
